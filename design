<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Corner Stone WhatsApp Reel</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.5/ScrollTrigger.min.js"></script>
<style>
:root{
  --accent:#128C7E;
  --white:#fff;
  --black:#111;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{width:100%;height:100%;background:var(--black);overflow:hidden;font-family:'Inter',sans-serif;}
.fill{position:absolute;inset:0;}
#main{background:radial-gradient(ellipse at center,#152119 0%,var(--black) 100%);color:var(--white);overflow:hidden;}

.header{position:absolute;top:0;left:0;right:0;height:90px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;opacity:0;}
.logo{font-size:32px;font-weight:800;color:var(--accent);}
.contact{font-size:22px;font-weight:500;}

.intro{position:absolute;bottom:12vh;left:40px;right:40px;opacity:0;display:flex;flex-direction:column;gap:32px;}
.title{font-size:76px;font-weight:800;letter-spacing:-1px;line-height:1.1;text-shadow:0 2px 120px rgba(0,0,0,.4),0 8px 20px rgba(0,0,0,.6);}
.subtitle{font-size:36px;line-height:1.3;}
.cta{display:flex;align-items:center;justify-content:center;gap:12px;height:90px;width:440px;background:var(--accent);color:var(--white);font-size:32px;font-weight:700;border-radius:12px;text-decoration:none;box-shadow:0 10px 30px -10px #000;}
.cta:hover{background:var(--white);color:var(--accent);}

.phone-group{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;transform:translateX(200px) rotate(18deg);}
.phone{position:relative;width:320px;height:640px;overflow:hidden;background:var(--black);border-radius:36px;box-shadow:0 0 0 4px #222,0 30px 80px rgba(0,0,0,.8);z-index:1;}
.notch{position:absolute;top:0;left:50%;translate:-50% 0;width:165px;height:28px;border-radius:0 0 16px 16px;background:var(--black);}
.screen{position:absolute;inset:0;background:#F4F2EB;background-size:cover;background-repeat:no-repeat;}
.statusbar{height:44px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;font-size:18px;font-weight:500;color:var(--white);}
.header{height:64px;background:var(--accent);padding:0 16px;display:flex;align-items:center;gap:12px;color:var(--white);}
.avatar{width:44px;height:44px;border-radius:8px;background:#25D366;color:var(--white);font-size:24px;font-weight:600;display:flex;align-items:center;justify-content:center;}
.name{font-size:18px;font-weight:600;}
.chat{position:absolute;top:108px;bottom:0;left:0;right:0;background-image:linear-gradient(#e0dad2 8.1%, transparent 0),linear-gradient(45deg,#dbd4cc 25%,transparent 0);background-size:100% 48px;background-position:0 10px;padding:0 16px;}
.bubble{margin-bottom:12px;padding:12px;background:#fff;box-shadow:0 1px 2px rgba(0,0,0,.15);border-radius:0 12px 12px 12px;max-width:85%;position:relative;}
.bubble.right{align-self:end;background:#D2F8C6;border-radius:12px 0 12px 12px;}
.bubble p{margin:8px 0;font-size:16px;line-height:1.4;}
.time{font-size:12px;color:#555;position:absolute;right:8px;bottom:4px;}

.phone-2{position:absolute;top:50%;left:45%;translate:-70% -50%;z-index:3;width:280px;height:560px;border-radius:26px;background:#0c0c0c;box-shadow:0 0 0 3px rgba(255,255,255,.15),0 20px 70px rgba(0,0,0,.7),20px 40px 90px rgba(0,0,0,.4),60px 120px 100px rgba(0,0,0,.2);}
.phone-2 .screen{background:#F4F2EB;}

.phone-3{position:absolute;bottom:10%;right:45%;translate:60% 60%;z-index:2;width:340px;height:680px;border-radius:40px;background:#101010;box-shadow:0 0 0 3px rgba(255,255,255,.2),0 40px 100px rgba(0,0,0,.8),30px 60px 120px rgba(0,0,0,.4);}

.split{display:flex;}
.side{width:50%;height:100%;display:flex;flex-direction:column;justify-content:flex-end;padding:5vw;}
.dash-title{font-size:48px;font-weight:800;margin-bottom:32px;}
.dash-title span{color:var(--accent);}
.left{background:linear-gradient(20deg,var(--black),#142d2a);}
.right{background:radial-gradient(100% 100% at 0% 0%,#1F3B32,var(--black));}
.icon{width:180px;height:180px;margin-bottom:40px;}

.end{padding:10vw;background:#000;}
.end-content{max-width:820px;margin:0 auto;display:flex;flex-direction:column;align-items:center;text-align:center;}
.end-title{font-size:90px;font-weight:800;line-height:1;margin-bottom:32px;}
.end-subtitle{font-size:36px;line-height:1.2;margin-bottom:64px;}
.end-cta{display:inline-block;background:var(--accent);color:var(--white);text-decoration:none;font-size:32px;font-weight:600;height:90px;padding:0 40px;border-radius:12px;display:flex;align-items:center;justify-content:center;}
</style>
</head>
<body>
<div id="main" class="fill">

  <div class="header">
    <div class="logo">Corner Stone</div>
    <div class="contact">+91 73765 79197</div>
  </div>

  <div class="intro">
    <div class="title">Your business on<br>WhatsApp, supercharged</div>
    <div class="subtitle">Connect with customers, automate sales,<br>and grow your business on India's #1 app</div>
    <a href="#" class="cta">Get Started →</a>
  </div>

  <div class="phone-group">
    <div class="phone">
      <div class="notch"></div>
      <div class="screen">
        <div class="statusbar">
          <div>9:42</div>
          <div>📶🔋</div>
        </div>
        <div class="header">
          <div class="avatar">SH</div>
          <div class="name">Sharma Electronics</div>
        </div>
        <div class="chat">
          <div class="bubble">
            <p>Hey there! Do you have any offers on 55" TVs currently?</p>
            <div class="time">10:26</div>
          </div>
          <div class="bubble right">
            <p>Hi! Yes we have a great deal on Samsung 55" QLED TVs this week - flat 20% off! 📺</p>
            <div class="time">10:28</div>
          </div>
          <div class="bubble right">
            <p>List price ₹85,000 - sale price ₹68,000 with free delivery and installation.</p>
            <div class="time">10:28</div>
          </div>
          <div class="bubble">
            <p>Awesome that sounds like a great offer! 😊 How long is this price valid for?</p>
            <div class="time">10:30</div>
          </div>
        </div>
      </div>
    </div>

    <div class="phone-2"></div>
    <div class="phone-3"></div>
  </div>

</div>

<div class="split">
  <div class="side left">
    <img class="icon" src="https://i.ibb.co/WVypcx7/chat.png" alt="Chat icon">
    <div class="dash-title">Delight customers with <span>instant replies</span> 24/7</div>
  </div>
  <div class="side right">
    <img class="icon" src="https://i.ibb.co/NYDL4qS/offer.png" alt="Offer icon">
    <div class="dash-title">Boost sales with <span>WhatsApp offers</span> and reminders</div>
  </div>
</div>

<div class="end">
  <div class="end-content">
    <div class="end-title">WhatsApp Marketing<br>for Serious Retailers</div>
    <div class="end-subtitle">Grow your business on the world's largest messaging app — with Corner Stone's advanced WhatsApp platform and marketing expertise</div>
    <a href="#" class="end-cta">Start Growing on WhatsApp →</a>
  </div>
</div>

<script>
gsap.registerPlugin(ScrollTrigger);

gsap.timeline({defaults:{duration:1,ease:"power2.out"}})
  .from('.header',{y:-90,opacity:0})
  .from('.intro',{x:-100,opacity:0},">-0.5")
  .from('.phone-group',{x:200,rotate:15},">-0.5")

gsap.timeline({defaults:{duration:1.5,ease:"power2.inOut"},scrollTrigger:{scrub:1,start:"top center",end:"bottom center"}})
  .to(".phone-group",{x:-200,y:100,rotate:-15},"<")
  .to(".intro",{opacity:0},"<")

gsap.timeline({scrollTrigger:{trigger:".end",start:"top 90%",toggleActions:"play none none reset"}})
  .from('.end-title',{y:100,opacity:0,duration:1,ease:"power2.out"})
  .from('.end-subtitle',{y:50,opacity:0,duration:0.8,ease:"power1.out"},">-0.2")
  .from('.end-cta',{scale:0,duration:0.5,ease:"back(3)"},">-0.2")
</script>

</body>
</html>
